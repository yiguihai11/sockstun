# Makefile for UDP bidirectional test

CC = gcc
CFLAGS = -Wall -Werror -g -I../src -I../src/core/include -I../src/misc -I../third-part/lwip/src/include -I../third-part/lwip/src/ports/include

LDFLAGS = -L../third-part/lwip/bin -llwip -lpthread

SRC = test-udp-bidirectional.c \
      ../src/route/hev-direct-udp.c \
      ../src/misc/hev-logger.c

OBJS = $(SRC:.c=.o)
TARGET = test-udp-bidirectional

.PHONY: all clean test

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CC) $(OBJS) -o $@ $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

test: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(OBJS) $(TARGET)