@@ -0,0 +1,269 @@
+/*
+ * ============================================================================
+ * Name        : simple-forward-tcp.c
+ * Author      : Custom Implementation
+ * Description : Simple TCP traffic forwarding implementation
+ * ============================================================================
+ */
+
+#include <errno.h>
+#include <string.h>
+#include <unistd.h>
+#include <sys/socket.h>
+#include <netinet/in.h>
+#include <arpa/inet.h>
+#include <fcntl.h>
+
+#include <lwip/tcp.h>
+
+#include <hev-task.h>
+#include <hev-task-io.h>
+#include <hev-task-io-socket.h>
+#include <hev-task-mutex.h>
+#include <hev-memory-allocator.h>
+#include <hev-logger.h>
+
+#include "simple-forward.h"
+#include "hev-config.h"
+
+static int
+task_io_yielder (HevTaskYieldType type, void *data)
+{
+    hev_task_yield (type);
+    return 0; // Always continue for now
+}
+
+static int
+tcp_splice_to_forward (SimpleForwardTCP *self)
+{
+    int res = 1;
+
+    // Read from LWIP buffer and write to forward socket
+    if (self->pcb) {
+        // Get data from LWIP PCB
+        // For simplicity, we'll read one packet at a time
+        // In real implementation, you might want to use a ring buffer
+        struct tcp_pcb *pcb = self->pcb;
+
+        // This is a simplified approach - in practice you'd need to handle
+        // the actual data flow from LWIP to the forward socket
+        // For now, we'll just acknowledge the data
+        if (pcb->recv) {
+            // Data is available, but we need to connect to forward port first
+            if (self->forward_fd >= 0) {
+                // Forward data to the specified port
+                // This is a placeholder - actual implementation needed
+                res = 1;
+            }
+        }
+    } else {
+        res = -1;
+    }
+
+    return res;
+}
+
+static int
+tcp_splice_from_forward (SimpleForwardTCP *self)
+{
+    // Read from forward socket and write to LWIP
+    if (self->forward_fd >= 0 && self->pcb) {
+        char buffer[4096];
+        ssize_t bytes_read = read(self->forward_fd, buffer, sizeof(buffer));
+
+        if (bytes_read > 0) {
+            // Write to LWIP PCB
+            err_t err = tcp_write(self->pcb, buffer, bytes_read, TCP_WRITE_FLAG_COPY);
+            if (err == ERR_OK) {
+                tcp_output(self->pcb);
+                return 1;
+            } else {
+                return -1;
+            }
+        } else if (bytes_read == 0) {
+            // Connection closed
+            return -1;
+        } else if (errno == EAGAIN || errno == EWOULDBLOCK) {
+            return 0;
+        } else {
+            return -1;
+        }
+    }
+
+    return -1;
+}
+
+static err_t
+tcp_recv_handler (void *arg, struct tcp_pcb *pcb, struct pbuf *p, err_t err)
+{
+    SimpleForwardTCP *self = arg;
+
+    if (p) {
+        // Data received from LWIP
+        // We need to forward this to our target port
+        if (self->forward_fd >= 0) {
+            // Forward the data
+            struct pbuf *q;
+            for (q = p; q != NULL; q = q->next) {
+                ssize_t written = write(self->forward_fd, q->payload, q->len);
+                if (written != (ssize_t)q->len) {
+                    // Handle write error
+                    break;
+                }
+            }
+            tcp_recved(pcb, p->tot_len);
+        }
+        pbuf_free(p);
+    } else {
+        // Connection closed by remote end
+        if (self->forward_fd >= 0) {
+            close(self->forward_fd);
+            self->forward_fd = -1;
+        }
+        self->pcb = NULL;
+    }
+
+    return ERR_OK;
+}
+
+static err_t
+tcp_sent_handler (void *arg, struct tcp_pcb *pcb, u16_t len)
+{
+    // Data sent acknowledgment
+    return ERR_OK;
+}
+
+static void
+tcp_err_handler (void *arg, err_t err)
+{
+    SimpleForwardTCP *self = arg;
+
+    if (self->forward_fd >= 0) {
+        close(self->forward_fd);
+        self->forward_fd = -1;
+    }
+    self->pcb = NULL;
+}
+
+static int
+connect_to_forward_port (int port)
+{
+    int fd;
+    struct sockaddr_in addr;
+
+    fd = socket(AF_INET, SOCK_STREAM, 0);
+    if (fd < 0) {
+        LOG_E("Failed to create socket for forward port %d", port);
+        return -1;
+    }
+
+    // Set non-blocking
+    int flags = fcntl(fd, F_GETFL, 0);
+    fcntl(fd, F_SETFL, flags | O_NONBLOCK);
+
+    memset(&addr, 0, sizeof(addr));
+    addr.sin_family = AF_INET;
+    addr.sin_addr.s_addr = htonl(INADDR_LOOPBACK); // Connect to localhost
+    addr.sin_port = htons(port);
+
+    if (connect(fd, (struct sockaddr*)&addr, sizeof(addr)) < 0) {
+        if (errno != EINPROGRESS) {
+            LOG_E("Failed to connect to forward port %d", port);
+            close(fd);
+            return -1;
+        }
+        // Connection in progress, we'll handle it in the event loop
+    }
+
+    return fd;
+}
+
+SimpleForwardTCP *
+simple_forward_tcp_new (struct tcp_pcb *pcb, HevTaskMutex *mutex, int forward_port)
+{
+    SimpleForwardTCP *self;
+
+    self = hev_malloc0(sizeof(SimpleForwardTCP));
+    if (!self)
+        return NULL;
+
+    self->mutex = mutex;
+    self->pcb = pcb;
+    self->forward_fd = connect_to_forward_port(forward_port);
+
+    if (self->forward_fd < 0) {
+        hev_free(self);
+        return NULL;
+    }
+
+    // Set up LWIP callbacks
+    tcp_arg(pcb, self);
+    tcp_recv(pcb, tcp_recv_handler);
+    tcp_sent(pcb, tcp_sent_handler);
+    tcp_err(pcb, tcp_err_handler);
+
+    LOG_D("%p simple forward tcp new", self);
+
+    return self;
+}
+
+void
+simple_forward_tcp_run (SimpleForwardTCP *self)
+{
+    LOG_D("%p simple forward tcp run", self);
+
+    // Main forwarding loop
+    while (self->pcb && self->forward_fd >= 0) {
+        // Check if we can read from forward socket
+        if (self->forward_fd >= 0) {
+            char buffer[4096];
+            ssize_t bytes_read = read(self->forward_fd, buffer, sizeof(buffer));
+
+            if (bytes_read > 0) {
+                // Send data back to LWIP
+                hev_task_mutex_lock(self->mutex);
+                if (self->pcb) {
+                    err_t err = tcp_write(self->pcb, buffer, bytes_read, TCP_WRITE_FLAG_COPY);
+                    if (err == ERR_OK) {
+                        tcp_output(self->pcb);
+                    }
+                }
+                hev_task_mutex_unlock(self->mutex);
+            } else if (bytes_read == 0) {
+                // Forward connection closed
+                break;
+            } else if (errno != EAGAIN && errno != EWOULDBLOCK) {
+                // Error on forward connection
+                break;
+            }
+        }
+
+        // Yield to allow other tasks to run
+        if (task_io_yielder(HEV_TASK_WAITIO, self) < 0) {
+            break;
+        }
+    }
+
+    // Cleanup
+    if (self->forward_fd >= 0) {
+        close(self->forward_fd);
+        self->forward_fd = -1;
+    }
+
+    hev_task_mutex_lock(self->mutex);
+    if (self->pcb) {
+        tcp_recv(self->pcb, NULL);
+        tcp_sent(self->pcb, NULL);
+        tcp_err(self->pcb, NULL);
+        tcp_abort(self->pcb);
+        self->pcb = NULL;
+    }
+    hev_task_mutex_unlock(self->mutex);
+}
+
+void
+simple_forward_tcp_free (SimpleForwardTCP *self)
+{
+    LOG_D("%p simple forward tcp free", self);
+    hev_free(self);
+}
