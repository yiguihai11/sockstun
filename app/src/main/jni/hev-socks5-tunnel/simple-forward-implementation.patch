+/*
+ * ============================================================================
+ * Name        : simple-forward-udp.c
+ * Author      : Custom Implementation
+ * Description : Simple UDP traffic forwarding implementation
+ * ============================================================================
+ */
+
+#include <errno.h>
+#include <string.h>
+#include <unistd.h>
+#include <sys/socket.h>
+#include <netinet/in.h>
+#include <arpa/inet.h>
+#include <fcntl.h>
+
+#include <lwip/udp.h>
+
+#include <hev-task.h>
+#include <hev-task-io.h>
+#include <hev-task-io-socket.h>
+#include <hev-task-mutex.h>
+#include <hev-memory-allocator.h>
+#include <hev-logger.h>
+
+#include "simple-forward.h"
+#include "hev-config.h"
+
+static int
+task_io_yielder (HevTaskYieldType type, void *data)
+{
+    hev_task_yield (type);
+    return 0; // Always continue for now
+}
+
+static void
+udp_recv_handler (void *arg, struct udp_pcb *pcb, struct pbuf *p,
+                  const ip_addr_t *addr, u16_t port)
+{
+    SimpleForwardUDP *self = arg;
+
+    if (p && self->forward_fd >= 0) {
+        // Forward UDP packet to the specified port
+        struct sockaddr_in forward_addr;
+        ssize_t bytes_sent;
+
+        memset(&forward_addr, 0, sizeof(forward_addr));
+        forward_addr.sin_family = AF_INET;
+        forward_addr.sin_addr.s_addr = htonl(INADDR_LOOPBACK);
+        forward_addr.sin_port = htons(1080); // Forward to port 1080
+
+        bytes_sent = sendto(self->forward_fd, p->payload, p->len, 0,
+                           (struct sockaddr*)&forward_addr, sizeof(forward_addr));
+
+        if (bytes_sent != (ssize_t)p->len) {
+            LOG_E("Failed to forward UDP packet: %s", strerror(errno));
+        }
+
+        pbuf_free(p);
+    } else if (p) {
+        pbuf_free(p);
+    }
+}
+
+static int
+connect_to_forward_port_udp (int port)
+{
+    int fd;
+
+    fd = socket(AF_INET, SOCK_DGRAM, 0);
+    if (fd < 0) {
+        LOG_E("Failed to create UDP socket for forward port %d", port);
+        return -1;
+    }
+
+    // Set non-blocking
+    int flags = fcntl(fd, F_GETFL, 0);
+    fcntl(fd, F_SETFL, flags | O_NONBLOCK);
+
+    // For UDP, we don't need to connect, but we can bind if needed
+    // For simplicity, we'll just use sendto/recvfrom
+
+    return fd;
+}
+
+SimpleForwardUDP *
+simple_forward_udp_new (struct udp_pcb *pcb, HevTaskMutex *mutex, int forward_port)
+{
+    SimpleForwardUDP *self;
+
+    self = hev_malloc0(sizeof(SimpleForwardUDP));
+    if (!self)
+        return NULL;
+
+    self->mutex = mutex;
+    self->pcb = pcb;
+    self->forward_fd = connect_to_forward_port_udp(forward_port);
+
+    if (self->forward_fd < 0) {
+        hev_free(self);
+        return NULL;
+    }
+
+    // Set up LWIP callback
+    udp_recv(pcb, udp_recv_handler, self);
+
+    LOG_D("%p simple forward udp new", self);
+
+    return self;
+}
+
+void
+simple_forward_udp_run (SimpleForwardUDP *self)
+{
+    LOG_D("%p simple forward udp run", self);
+
+    // For UDP, we mainly handle incoming packets via callback
+    // But we also need to handle responses from the forward port
+    while (self->pcb && self->forward_fd >= 0) {
+        // Check for responses from forward port
+        char buffer[4096];
+        struct sockaddr_in src_addr;
+        socklen_t src_len = sizeof(src_addr);
+        ssize_t bytes_read = recvfrom(self->forward_fd, buffer, sizeof(buffer), 0,
+                                     (struct sockaddr*)&src_addr, &src_len);
+
+        if (bytes_read > 0) {
+            // Send response back through LWIP
+            struct pbuf *p = pbuf_alloc(PBUF_TRANSPORT, bytes_read, PBUF_RAM);
+            if (p) {
+                memcpy(p->payload, buffer, bytes_read);
+                hev_task_mutex_lock(self->mutex);
+                if (self->pcb) {
+                    // Send back to original source
+                    // Note: In real implementation, you'd need to track the mapping
+                    // between original source and forward destination
+                    ip_addr_t dest_addr;
+                    IP_ADDR4(&dest_addr, 198, 18, 0, 2); // Example DNS address
+                    udp_sendto(self->pcb, p, &dest_addr, 53);
+                }
+                hev_task_mutex_unlock(self->mutex);
+                pbuf_free(p);
+            }
+        } else if (errno != EAGAIN && errno != EWOULDBLOCK) {
+            // Error on forward connection
+            break;
+        }
+
+        // Yield to allow other tasks to run
+        if (task_io_yielder(HEV_TASK_WAITIO, self) < 0) {
+            break;
+        }
+    }
+
+    // Cleanup
+    if (self->forward_fd >= 0) {
+        close(self->forward_fd);
+        self->forward_fd = -1;
+    }
+
+    hev_task_mutex_lock(self->mutex);
+    if (self->pcb) {
+        udp_recv(self->pcb, NULL, NULL);
+        udp_remove(self->pcb);
+        self->pcb = NULL;
+    }
+    hev_task_mutex_unlock(self->mutex);
+}
+
+void
+simple_forward_udp_free (SimpleForwardUDP *self)
+{
+    LOG_D("%p simple forward udp free", self);
+    hev_free(self);
+}
