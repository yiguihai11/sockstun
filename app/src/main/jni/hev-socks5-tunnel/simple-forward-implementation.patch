index 0000000..5d45cb4
--- /dev/null
+++ b/src/custom/simple-forward.h
@@ -0,0 +1,55 @@
+/*
+ * ============================================================================
+ * Name        : simple-forward.h
+ * Author      : Custom Implementation
+ * Description : Simple traffic forwarding without SOCKS5 core library
+ * ============================================================================
+ */
+
+#ifndef __SIMPLE_FORWARD_H__
+#define __SIMPLE_FORWARD_H__
+
+#include <lwip/tcp.h>
+#include <lwip/udp.h>
+
+#include <hev-task.h>
+#include <hev-task-mutex.h>
+
+#include "hev-tunnel.h"
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+typedef struct _SimpleForwardTCP SimpleForwardTCP;
+typedef struct _SimpleForwardUDP SimpleForwardUDP;
+
+struct _SimpleForwardTCP {
+    HevTask *task;
+    HevTaskMutex *mutex;
+    struct tcp_pcb *pcb;
+    int forward_fd;  // File descriptor to forward traffic to (e.g., 1080 port)
+};
+
+struct _SimpleForwardUDP {
+    HevTask *task;
+    HevTaskMutex *mutex;
+    struct udp_pcb *pcb;
+    int forward_fd;  // File descriptor to forward traffic to
+};
