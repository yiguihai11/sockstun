<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- iOS-inspired base theme -->
    <style name="Theme.SocksTun" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:colorPrimary">@color/ios_system_blue</item>
        <item name="colorPrimaryContainer">@color/ios_system_blue_container</item>
        <item name="android:colorBackground">@color/ios_system_background</item>
        
        <!-- Typography -->
        <item name="textAppearanceTitleLarge">@style/TextAppearance.IOS.TitleLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.IOS.Body</item>

        <!-- Component shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.IOS.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.IOS.Medium</item>

        <!-- List item metrics -->
        <item name="listItemVerticalPadding">@dimen/list_item_vertical_padding</item>
        <item name="listItemHorizontalPadding">@dimen/list_item_horizontal_padding</item>
    </style>

    <!-- iOS-style text appearances -->
    <style name="TextAppearance.IOS.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:lineHeight">32sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.IOS.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="ShapeAppearance.IOS.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.IOS.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>